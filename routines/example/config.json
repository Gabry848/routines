{
  "scheduler": {
    "enabled": true,
    "timezone": "Europe/Rome",
    "tasks": [
      {
        "task_id": "health-check",
        "job_name": "System Health Check",
        "enabled": true,
        "schedule": {
          "type": "cron",
          "expression": "*/30 * * * *"
        },
        "startup_script": "setup.sh"
      }
    ]
  },
  "model_config": {
    "model": "haiku",
    "allowed_tools": ["Bash", "Read", "Write", "GlobMatch", "GrepSearch"]
  },
  "docker": {
    "enabled": false
  },
  "environment": {
    "isolated_runs": false,
    "keep_executions": false
  }
}
