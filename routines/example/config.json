{
  "scheduler": {
    "enabled": true,
    "timezone": "Europe/Rome",
    "tasks": [
      {
        "job_name": "example-cron-job",
        "schedule": {
          "type": "cron",
          "expression": "30 9 * * *"
        },
        "startup_script": "setup.sh"
      }
    ]
  },
  "model_config": {
    "model": "haiku",
    "allowed_tools": ["Bash", "GlobMatch", "GrepSearch", "LS", "View", "FileRead", "FileWriView", "FileRead", "FileWritete"]
  },
  "docker": {
    "enabled": true,
    "image": "node:20",
    "network": "bridge"
  },
  "environment": {
    "isolated_runs": true,
    "keep_executions": true
  }
}
